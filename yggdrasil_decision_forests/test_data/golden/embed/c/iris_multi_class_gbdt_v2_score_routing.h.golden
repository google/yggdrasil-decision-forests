/*
   ydf_model.h - Single-Header C Library for YDF Model Prediction
   
   USAGE:
   
   1. In EXACTLY ONE .c file, define the implementation before including:
      #define YDF_MODEL_YDF_MODEL_IMPL_
      #include "ydf_model.h"

   2. In all other .c files, just include it normally:
      #include "ydf_model.h"
*/

#ifndef YDF_MODEL_YDF_MODEL_H_
#define YDF_MODEL_YDF_MODEL_H_

#include <stdint.h>

#ifdef __cplusplus
extern "C" {
#endif  // __cplusplus

typedef enum {
  YdfModel_LabelEnum_Setosa = 0,
  YdfModel_LabelEnum_Versicolor = 1,
  YdfModel_LabelEnum_Virginica = 2,
} YdfModel_LabelEnum;
typedef uint32_t YdfModel_Label;

typedef float YdfModel_Numerical;

typedef struct {
  YdfModel_Numerical sepal_length;
  YdfModel_Numerical sepal_width;
  YdfModel_Numerical petal_length;
  YdfModel_Numerical petal_width;
} YdfModel_Instance;

// Prediction function.
// The results are written into the provided `out` array.
//
// Sanitizes the given instance, then calls `YdfModel_PredictUnsafe()`.
void YdfModel_Predict(const YdfModel_Instance* instance, float out[3]);

// Predicts on an instance without any safety checks.
// The results are written into the provided `out` array.
//
// The caller must ensure that the instance meets the following conditions:
// - Numerical features must not be NaN.
// - Integerized categorical features must be within the range [0, max_value],
//   where max_value is the maximum value observed during training.
//
// Failure to meet these conditions may result in undefined behavior.
//
// It is recommended to use `YdfModel_Predict()` instead, unless the instance has
// already been sanitized.
//
// This function is called by `YdfModel_Predict()`.
void YdfModel_PredictUnsafe(const YdfModel_Instance* instance, float out[3]);

#ifdef __cplusplus
}
#endif  // __cplusplus

#endif  // YDF_MODEL_YDF_MODEL_H_

// This code is compiled ONLY when YDF_MODEL_YDF_MODEL_IMPL_ is defined.
#ifdef YDF_MODEL_YDF_MODEL_IMPL_

#include <assert.h>
#include <math.h>
#include <stddef.h>
#include <stdint.h>

// Portable packing macros.
#if defined(__KERNEL__) || defined(MODULE)
    #define YDF_MODEL_PACK_PUSH
    #define YDF_MODEL_PACK_POP
    #define YDF_MODEL_PACKED_ATTR __packed
#elif defined(_MSC_VER)
    #define YDF_MODEL_PACK_PUSH __pragma(pack(push, 1))
    #define YDF_MODEL_PACK_POP __pragma(pack(pop))
    #define YDF_MODEL_PACKED_ATTR
#elif defined(__GNUC__) || defined(__clang__)
    #define YDF_MODEL_PACK_PUSH
    #define YDF_MODEL_PACK_POP
    #define YDF_MODEL_PACKED_ATTR __attribute__((packed))
#else
    #define YDF_MODEL_PACK_PUSH
    #define YDF_MODEL_PACK_POP
    #define YDF_MODEL_PACKED_ATTR
#endif

static const uint8_t YdfModel_NumTrees = 3;

YDF_MODEL_PACK_PUSH
typedef struct YDF_MODEL_PACKED_ATTR {
  uint8_t pos;
  union {
    struct YDF_MODEL_PACKED_ATTR {
      uint8_t feat;
      union {
        float thr;
      };
    } cond;
    struct YDF_MODEL_PACKED_ATTR {
      float val;
    } leaf;
  };
} YdfModel_Node;
YDF_MODEL_PACK_POP

static const YdfModel_Node YdfModel_nodes[] = {
{.pos=1,.cond={.feat=3,.thr=0.8}},
{.leaf={.val=0.3}},
{.pos=1,.cond={.feat=2,.thr=3.65}},
{.leaf={.val=-0.15}},
{.leaf={.val=-0.15}},
{.pos=3,.cond={.feat=3,.thr=0.8}},
{.pos=1,.cond={.feat=2,.thr=1.45}},
{.leaf={.val=-0.15}},
{.leaf={.val=-0.15}},
{.pos=5,.cond={.feat=3,.thr=1.75}},
{.pos=3,.cond={.feat=2,.thr=4.95}},
{.pos=1,.cond={.feat=0,.thr=5.3}},
{.leaf={.val=0.21}},
{.leaf={.val=0.3}},
{.leaf={.val=0.03}},
{.pos=1,.cond={.feat=2,.thr=4.95}},
{.leaf={.val=-0.06}},
{.pos=1,.cond={.feat=0,.thr=7.25}},
{.leaf={.val=-0.15}},
{.leaf={.val=-0.15}},
{.pos=7,.cond={.feat=3,.thr=1.65}},
{.pos=5,.cond={.feat=2,.thr=4.85}},
{.pos=3,.cond={.feat=3,.thr=0.35}},
{.pos=1,.cond={.feat=1,.thr=3.45}},
{.leaf={.val=-0.15}},
{.leaf={.val=-0.15}},
{.leaf={.val=-0.15}},
{.leaf={.val=0.075}},
{.pos=1,.cond={.feat=2,.thr=5.05}},
{.leaf={.val=0.2}},
{.leaf={.val=0.3}},
};


static const uint8_t YdfModel_root_deltas[] = {5,15,11};

static const size_t YdfModel_FeatureOffsets[] = {
    offsetof(YdfModel_Instance, sepal_length),
    offsetof(YdfModel_Instance, sepal_width),
    offsetof(YdfModel_Instance, petal_length),
    offsetof(YdfModel_Instance, petal_width),
};

void YdfModel_PredictUnsafe(const YdfModel_Instance* instance, float out[3]) {
    out[0] = 0;
  out[1] = 0;
  out[2] = 0;


  const YdfModel_Node* root = YdfModel_nodes;
  const YdfModel_Node* node;
  const char* raw_instance = (const char*)(instance);
  uint8_t eval;
  for (uint8_t tree_idx = 0; tree_idx != YdfModel_NumTrees; tree_idx++) {
    node = root;
    while(node->pos) {
      const size_t off = YdfModel_FeatureOffsets[node->cond.feat];
        float numerical_feature = *(float*)(raw_instance + off);
        eval = numerical_feature >= node->cond.thr;

      node += (node->pos & -eval) + 1;
    }
    out[tree_idx % 3] += node->leaf.val;
    root += YdfModel_root_deltas[tree_idx];
  }

  
}

void YdfModel_Predict(const YdfModel_Instance* instance, float out[3]) {
  YdfModel_Instance sanitized_instance = *instance;
  sanitized_instance.sepal_length = isnan(instance->sepal_length) ? 5.84333 : instance->sepal_length;
  sanitized_instance.sepal_width = isnan(instance->sepal_width) ? 3.05733 : instance->sepal_width;
  sanitized_instance.petal_length = isnan(instance->petal_length) ? 3.758 : instance->petal_length;
  sanitized_instance.petal_width = isnan(instance->petal_width) ? 1.19933 : instance->petal_width;

  YdfModel_PredictUnsafe(&sanitized_instance, out);
}

#endif  // YDF_MODEL_YDF_MODEL_IMPL_
