static const u8 YdfModel_condition_types[] = {0,1,0,1,0,1,1,1,1,1,0,0,0,1};


static const u8 YdfModel_root_deltas[] = {55,57,57};


static const u8 YdfModel_categorical_bank[] = {0x38,0x4,0x46,0x36,0x98,0xed,0x80,0x41,0xc2,0x4,0xfb,0xdf,0x32,0x48,0x8c,0x6c,0x30,0xdb,0x1,0x83,0x4,0x4,0x20,0x38,0x20,0x0,0x1b,0xc,0x80,0xda,0x31,0x80,0x0,0x4a,0xec,0x8d,0x7c,0x32,0xdb,0xc1,0x6,0xf3,0xdf,0x0};

static const size_t YdfModel_FeatureOffsets[] = {
    offsetof(YdfModel_Instance, age),
    offsetof(YdfModel_Instance, workclass),
    offsetof(YdfModel_Instance, fnlwgt),
    offsetof(YdfModel_Instance, education),
    offsetof(YdfModel_Instance, education_num),
    offsetof(YdfModel_Instance, marital_status),
    offsetof(YdfModel_Instance, occupation),
    offsetof(YdfModel_Instance, relationship),
    offsetof(YdfModel_Instance, race),
    offsetof(YdfModel_Instance, sex),
    offsetof(YdfModel_Instance, capital_gain),
    offsetof(YdfModel_Instance, capital_loss),
    offsetof(YdfModel_Instance, hours_per_week),
    offsetof(YdfModel_Instance, native_country),
};

s32 YdfModel_Predict(const YdfModel_Instance* instance) {
  s32 accumulator = -76225;

  const YdfModel_Node* root = YdfModel_nodes;
  const YdfModel_Node* node;
  const char* raw_instance = (const char*)(instance);
  u8 eval;
  for (u8 tree_idx = 0; tree_idx != YdfModel_NumTrees; tree_idx++) {
    node = root;
    while(node->pos) {
      if (YdfModel_condition_types[node->cond.feat] == 0) {
        const size_t off = YdfModel_FeatureOffsets[node->cond.feat];
        s32 numerical_feature = *(s32*)(raw_instance + off);
        eval = numerical_feature >= node->cond.thr;
      } else if (YdfModel_condition_types[node->cond.feat] == 1) {
        const size_t off = YdfModel_FeatureOffsets[node->cond.feat];
        u32 categorical_feature = *(u32*)(raw_instance + off);
        eval = YdfModel_BitTest(YdfModel_categorical_bank, categorical_feature + node->cond.cat);
      } else {
        BUG();
      }
      node += (node->pos & -eval) + 1;
    }
    accumulator += node->leaf.val;
    root += YdfModel_root_deltas[tree_idx];
  }

  return accumulator;
}

#endif  // YDF_MODEL_YDF_MODEL_IMPL_
