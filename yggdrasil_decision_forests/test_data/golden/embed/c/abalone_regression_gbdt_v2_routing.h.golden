static const uint8_t YdfModel_condition_types[] = {1,0,0,0,0,0,0,0};


static const uint8_t YdfModel_root_deltas[] = {63,63,63};


static const uint8_t YdfModel_categorical_bank[] = {0xb3,0x3b,0xbb};

static const size_t YdfModel_FeatureOffsets[] = {
    offsetof(YdfModel_Instance, type),
    offsetof(YdfModel_Instance, longestshell),
    offsetof(YdfModel_Instance, diameter),
    offsetof(YdfModel_Instance, height),
    offsetof(YdfModel_Instance, wholeweight),
    offsetof(YdfModel_Instance, shuckedweight),
    offsetof(YdfModel_Instance, visceraweight),
    offsetof(YdfModel_Instance, shellweight),
};

float YdfModel_PredictUnsafe(const YdfModel_Instance* instance) {
  float accumulator = 9.94246;

  const YdfModel_Node* root = YdfModel_nodes;
  const YdfModel_Node* node;
  const char* raw_instance = (const char*)(instance);
  uint8_t eval;
  for (uint8_t tree_idx = 0; tree_idx != YdfModel_NumTrees; tree_idx++) {
    node = root;
    while(node->pos) {
      if (YdfModel_condition_types[node->cond.feat] == 0) {
        const size_t off = YdfModel_FeatureOffsets[node->cond.feat];
        float numerical_feature = *(float*)(raw_instance + off);
        eval = numerical_feature >= node->cond.thr;
      } else if (YdfModel_condition_types[node->cond.feat] == 1) {
        const size_t off = YdfModel_FeatureOffsets[node->cond.feat];
        uint32_t categorical_feature = *(uint32_t*)(raw_instance + off);
        eval = YdfModel_BitTest(YdfModel_categorical_bank, categorical_feature + node->cond.cat);
      } else {
        assert(false);
      }
      node += (node->pos & -eval) + 1;
    }
    accumulator += node->leaf.val;
    root += YdfModel_root_deltas[tree_idx];
  }

  return accumulator;
}

float YdfModel_Predict(const YdfModel_Instance* instance) {
  YdfModel_Instance sanitized_instance = *instance;
  sanitized_instance.longestshell = isnan(instance->longestshell) ? 0.523992 : instance->longestshell;
  sanitized_instance.diameter = isnan(instance->diameter) ? 0.407881 : instance->diameter;
  sanitized_instance.height = isnan(instance->height) ? 0.139516 : instance->height;
  sanitized_instance.wholeweight = isnan(instance->wholeweight) ? 0.828742 : instance->wholeweight;
  sanitized_instance.shuckedweight = isnan(instance->shuckedweight) ? 0.359367 : instance->shuckedweight;
  sanitized_instance.visceraweight = isnan(instance->visceraweight) ? 0.180594 : instance->visceraweight;
  sanitized_instance.shellweight = isnan(instance->shellweight) ? 0.238831 : instance->shellweight;

  return YdfModel_PredictUnsafe(&sanitized_instance);
}

#endif  // YDF_MODEL_YDF_MODEL_IMPL_
