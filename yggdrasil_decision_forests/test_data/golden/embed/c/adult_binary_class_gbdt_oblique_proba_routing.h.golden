float YdfModel_Predict(const YdfModel_Instance* instance) {
  float accumulator = -1.1631;

  const YdfModel_Node* root = YdfModel_nodes;
  const YdfModel_Node* node;
  const char* raw_instance = (const char*)(instance);
  uint8_t eval;
  for (uint8_t tree_idx = 0; tree_idx != YdfModel_NumTrees; tree_idx++) {
    node = root;
    while(node->pos) {
      if (node->cond.feat == 255) {
        const uint8_t num_projs = YdfModel_oblique_features[node->cond.obl];
        float obl_acc = -YdfModel_oblique_weights[node->cond.obl];
        for (uint8_t proj_idx=0; proj_idx<num_projs; proj_idx++){
          const size_t proj_off = node->cond.obl + proj_idx + 1;
          int32_t numerical_feature;
          const uint8_t feat_idx = YdfModel_oblique_features[proj_off];
          const size_t safe_off = YdfModel_FeatureOffsets[feat_idx];
          memcpy(&numerical_feature, raw_instance + safe_off, sizeof(int32_t));
          obl_acc += numerical_feature * YdfModel_oblique_weights[proj_off];
        }
        eval = obl_acc >= 0;
      } else if (YdfModel_condition_types[node->cond.feat] == 1) {
        const size_t off = YdfModel_FeatureOffsets[node->cond.feat];
        uint32_t categorical_feature = *(uint32_t*)(raw_instance + off);
        eval = YdfModel_BitTest(YdfModel_categorical_bank, categorical_feature + node->cond.cat);
      } else {
        assert(false);
      }
      node += (node->pos & -eval) + 1;
    }
    accumulator += node->leaf.val;
    root += YdfModel_root_deltas[tree_idx];
  }

  return 1.f / (1.f + expf(-accumulator));
}

#endif  // YDF_MODEL_YDF_MODEL_IMPL_
