# Bazel configuration for YDF-TF
#
# Windows support not added yet.

common --enable_platform_specific_config

# Use Tensorflow for file system calls. YDF's default filesystem also works
# for local files. Consider deprecating YDF's TensorFlow filesystem and use
# the default file system instead.
build --define=use_tensorflow_io=1

build -c opt
build --announce_rc
build --color=yes

build:linux --copt=-fdiagnostics-color=always
build:linux --copt=-w
build:linux --host_copt=-w
build:linux --cxxopt=-std=c++17
build:linux --host_cxxopt=-std=c++17
build:macos --cxxopt=-std=c++17
build:macos --host_cxxopt=-std=c++17

build:macos --copt=-w

build:windows --copt=/W0
